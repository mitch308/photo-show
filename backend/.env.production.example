# Server
PORT=3000
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=photo_show
DB_PASSWORD=<change-me-to-strong-password>
DB_NAME=photo_show

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=<generate-secure-random-string-using-openssl-rand-hex-32>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Upload
UPLOAD_DIR=/var/www/photo-show/uploads
MAX_FILE_SIZE=52428800